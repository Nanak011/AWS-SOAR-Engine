{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowEC2NetworkContainment",
      "Effect": "Allow",
      "Action": [
        "ec2:ModifyInstanceAttribute",
        "ec2:DescribeInstances"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowReadingWafLogs",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::aws-waf-logs-soar-production",
        "arn:aws:s3:::aws-waf-logs-soar-production/*"
      ]
    }
  ]
}
